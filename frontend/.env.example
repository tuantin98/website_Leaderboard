# Leave these UNSET to auto-detect the backend from the browser's hostname
# (so phones on the LAN reach http://<laptop-ip>:5000 automatically).
# Only set them to pin the backend to a fixed address.
# VITE_API_URL=http://localhost:5000/api
# VITE_SOCKET_URL=http://localhost:5000
# VITE_BACKEND_PORT=5000
